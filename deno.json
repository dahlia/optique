{
  "workspace": [
    "packages/*",
    "examples/*"
  ],
  "imports": {
    "@clack/prompts": "npm:@clack/prompts@^1.6.0",
    "@inquirer/prompts": "npm:@inquirer/prompts@^8.3.0",
    "@logtape/file": "jsr:@logtape/file@^2.0.4",
    "@logtape/logtape": "jsr:@logtape/logtape@^2.0.4",
    "@standard-schema/spec": "npm:@standard-schema/spec@^1.1.0",
    "@std/fs": "jsr:@std/fs@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.1",
    "@types/node": "npm:@types/node@^24.0.0",
    "fast-check": "npm:fast-check@^4.7.0",
    "isomorphic-git": "npm:isomorphic-git@^1.36.1",
    "markdownlint-cli2": "npm:markdownlint-cli2@^0.20.0",
    "tsdown": "npm:tsdown@^0.13.0",
    "typescript": "npm:typescript@^5.8.3",
    "valibot": "jsr:@valibot/valibot@^1.2.0",
    "zod": "npm:zod@^4.0.0"
  },
  "unstable": [
    "temporal"
  ],
  "exclude": [
    ".agents/",
    ".claude/",
    ".github/",
    "docs"
  ],
  "fmt": {
    "exclude": [
      "*.md",
      "**/*.md",
      "*.yaml",
      "**/*.yaml",
      "*.yml",
      "**/*.yml",
      "packages/config/src/test-configs/*.json"
    ]
  },
  "tasks": {
    "check-versions": "deno run --allow-read --allow-write scripts/check_versions.ts",
    "test": "deno test --allow-read --allow-write --allow-run --allow-env --allow-net --allow-sys --allow-ffi --env-file=.env.test"
  }
}
